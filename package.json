{
  "name": "@susutawar/ragi",
  "version": "0.1.1",
  "description": "Local-first RAG indexing and semantic search MCP server",
  "type": "module",
  "bin": {
    "ragi": "./bin/ragi.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "CHANGELOG.md",
    "bin",
    "dist",
    "scripts",
    "skills"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "start": "node dist/mcp/server.js",
    "test:unit": "vitest run --environment node --globals --dir src --pool threads",
    "test:init": "node scripts/docs-upsert.test.mjs",
    "test": "npm run test:unit && npm run test:init",
    "check": "npm run build && npm run test && node scripts/release-checks.mjs validate",
    "release:validate": "node scripts/release-checks.mjs validate",
    "release:assert-clean": "node scripts/release-checks.mjs assert-clean",
    "release:assert-main": "node scripts/release-checks.mjs assert-main",
    "release:pack": "node scripts/release-checks.mjs pack-dry-run",
    "release:prepare": "node scripts/release-checks.mjs assert-clean && npm run check",
    "release:publish": "node scripts/release-checks.mjs publish",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.2",
    "@xenova/transformers": "^2.17.2",
    "cheerio": "^1.2.0",
    "sqlite-vec": "^0.1.9"
  },
  "keywords": [
    "rag",
    "mcp",
    "embedding",
    "vector-search",
    "sqlite-vec",
    "ollama",
    "transformers"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SusuTawar/ragi"
  }
}
